{
    "swagger": "2.0",
    "info": {
        "description": "Starter API built with Gin following Onion Architecture.",
        "title": "Gin Quickstart API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
